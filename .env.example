# Copy this file to .env (local dev) and set real values.
# In Cloudflare Pages, set these as project Environment Variables / Secrets.

# --- Supabase ---
# Project URL, e.g. https://abcdxyz.supabase.co
PUBLIC_SUPABASE_URL=
# anon (public) key — read-only access to verified corridors via RLS
PUBLIC_SUPABASE_ANON_KEY=
# service-role key — SERVER ONLY, used for writes/generation. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Gemini ---
# Google AI Studio API key
GEMINI_API_KEY=
# Model id (default below is a good cost/quality balance)
GEMINI_MODEL=gemini-2.5-flash

# --- Google AdSense (leave blank until approved) ---
PUBLIC_ADSENSE_CLIENT=

# --- Google Cloud / Vertex AI (for on-demand generation from Cloudflare) ---
# Leave blank to keep using the AI Studio key above (batch/script generation).
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
# Service-account JSON — paste the whole JSON, or a base64 of it (one line).
GCP_SA_KEY=
