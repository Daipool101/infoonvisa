---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import DisclaimerModal from '../components/DisclaimerModal.astro';
import { getEnv } from '../lib/supabase';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  jsonLd?: object | object[];
  showDisclaimer?: boolean;
  hideChrome?: boolean; // skip the shared Nav/Footer (page supplies its own)
}

const {
  title,
  description = 'Clear, verified visa and trip guides for any From → To corridor. One trustworthy page per route.',
  canonical,
  noindex = false,
  jsonLd,
  showDisclaimer = false,
  hideChrome = false,
} = Astro.props;

const env = getEnv();
const adsenseClient = env.PUBLIC_ADSENSE_CLIENT;
const GA_ID = 'G-CE9NDE5Q6Y'; // Google Analytics 4 measurement ID
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL('/og-default.png', Astro.site).toString();

// Site-wide Organization entity: connects the brand to its logo and social
// profiles (sameAs) for Google's knowledge graph + AI search engines.
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'InfoOnVisa',
  url: 'https://infoonvisa.com/',
  logo: 'https://infoonvisa.com/logo-icon.png',
  email: 'contact@infoonvisa.com',
  sameAs: [
    'https://www.linkedin.com/company/infoonvisa1/',
    'https://www.instagram.com/infoonvisa',
  ],
};

const ldArray = [...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []), orgLd];
// Escape so AI/user content can't break out of the <script> block (e.g. "</script>").
const jsonLdSafe = (o: object) =>
  JSON.stringify(o).replace(/</g, '\\u003c').replace(/>/g, '\\u003e').replace(/&/g, '\\u0026');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      try { if (localStorage.getItem('iov-theme') === 'dark') document.documentElement.dataset.theme = 'dark'; } catch (e) {}
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="InfoOnVisa" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet" />

    {ldArray.map((ld) => (
      <script type="application/ld+json" set:html={jsonLdSafe(ld)} />
    ))}

    {adsenseClient && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
        crossorigin="anonymous"></script>
    )}

    <!-- Google tag (gtag.js) -->
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script is:inline define:vars={{ GA_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', GA_ID);
    </script>
  </head>
  <body>
    {!hideChrome && <Nav />}
    <main>
      <slot />
    </main>
    {!hideChrome && <Footer />}
    {showDisclaimer && <DisclaimerModal />}
  </body>
</html>
