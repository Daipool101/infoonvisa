  @media (max-width: 540px) { .know-grid { grid-template-columns: 1fr; } }
  .know-best { border-radius: .75rem; background: color-mix(in oklab, var(--primary) 5%, transparent); border: 1px solid color-mix(in oklab, var(--primary) 20%, transparent); padding: 1.25rem; }
