<script>
  // Visa type dropdown → show selected panel
  const sel = document.getElementById('visa-select') as HTMLSelectElement | null;
  const panels = Array.from(document.querySelectorAll<HTMLElement>('#visa-panels .vpanel'));
  sel?.addEventListener('change', () => panels.forEach((p) => (p.hidden = p.dataset.i !== sel.value)));

  // Documents checklist progress
  const docRoot = document.getElementById('iov-docs');
  if (docRoot) {
    const checks = Array.from(docRoot.querySelectorAll<HTMLInputElement>('.doc-check'));
    const fill = document.getElementById('doc-fill');
    const sub = document.getElementById('doc-sub');
    const update = () => {
      const done = checks.filter((c) => c.checked).length;
      if (fill) fill.style.width = `${(done / checks.length) * 100}%`;
      if (sub) sub.textContent = `Tick items as you collect them — ${done} of ${checks.length} ready.`;
    };
    checks.forEach((c) => c.addEventListener('change', () => {
      c.closest('.doc')?.classList.toggle('checked', c.checked);
      update();
    }));
  }

  // FAQ accordion
  document.querySelectorAll('.faqs .faq-q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const wasOpen = item?.classList.contains('open');
      document.querySelectorAll('.faqs .faq-item').forEach((i) => i.classList.remove('open'));
      if (!wasOpen) item?.classList.add('open');
    });
  });
</script>
