  .know-places { border-radius: .75rem; background: var(--cream); border: 1px solid var(--border); padding: 1.25rem; }
  .know-places ul { margin-top: .5rem; list-style: none; display: flex; flex-direction: column; gap: .375rem; font-size: .875rem; color: color-mix(in oklab, var(--navy) 85%, transparent); }

  /* FAQ */
  .faqs { list-style: none; }
  .faqs .faq-item { border-top: 1px solid var(--border); }
  .faqs .faq-item:first-child { border-top: none; }
  .faq-q { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1rem 0; text-align: left; background: none; border: none; cursor: pointer; font-family: var(--font-display); font-weight: 700; color: var(--navy); font-size: 1rem; }
