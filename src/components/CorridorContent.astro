---
import type { CorridorData } from '../lib/corridor';
import { VERDICT_LABEL, isGoodVerdict, safeUrl } from '../lib/corridor';
import type { Country } from '../lib/countries';

interface Props {
  data: CorridorData;
  from: Country;
  to: Country;
  verifiedDate: string;
  status: string;
}
const { data, from, to, verifiedDate, status } = Astro.props;
const good = isGoodVerdict(data.verdict);
const opt = data.visaOptions?.[0];

const I: Record<string, string> = {
  fileText: '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/>',
  fileCheck: '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m9 15 2 2 4-4"/>',
  mapPin: '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>',
  sparkles: '<path d="M9.94 14.06A2 2 0 0 0 8.5 12.6l-5.1-1.3a.5.5 0 0 1 0-.96l5.1-1.32A2 2 0 0 0 9.94 7.5l1.32-5.1a.5.5 0 0 1 .96 0l1.3 5.1a2 2 0 0 0 1.44 1.44l5.1 1.3a.5.5 0 0 1 0 .98l-5.1 1.3a2 2 0 0 0-1.44 1.44l-1.3 5.1a.5.5 0 0 1-.96 0z"/>',
  bookOpen: '<path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/>',
  info: '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>',
  calendar: '<rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M8 2v4"/><path d="M16 2v4"/>',
  shield: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>',
  shieldPlain: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>',
  externalLink: '<path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>',
  checkCircle: '<circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/>',
  alert: '<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/>',
  arrowRight: '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>',
  chevron: '<path d="m6 9 6 6 6-6"/>',
  wifi: '<path d="M12 20h.01"/><path d="M2 8.82a15 15 0 0 1 20 0"/><path d="M5 12.86a10 10 0 0 1 14 0"/><path d="M8.5 16.43a5 5 0 0 1 7 0"/>',
  plane: '<path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/>',
  hotel: '<path d="M10 22v-6.57"/><path d="M12 11h.01"/><path d="M12 7h.01"/><path d="M14 15.43V22"/><path d="M15 16a5 5 0 0 0-6 0"/><path d="M16 11h.01"/><path d="M16 7h.01"/><path d="M8 11h.01"/><path d="M8 7h.01"/><rect x="4" y="2" width="16" height="20" rx="2"/>',
};

const ESSENTIALS = [
  { icon: 'shieldPlain', title: 'Travel insurance', desc: 'Cover for medical emergencies & delays.', cta: 'Compare plans' },
  { icon: 'wifi', title: 'eSIM & data', desc: 'Get online the moment you land.', cta: 'Get an eSIM' },
  { icon: 'plane', title: 'Flights', desc: `Compare routes to ${to.name}.`, cta: 'Find flights' },
  { icon: 'hotel', title: 'Stays', desc: 'Hotels & rentals at your destination.', cta: 'Browse stays' },
];
---

<!-- Breadcrumbs -->
<nav class="crumbs">
  <a href="/">Home</a><span>/</span><span>Routes</span><span>/</span><span class="here">{from.name} → {to.name}</span>
</nav>

<!-- Verdict -->
<section class={`verdict${good ? ' good' : ''}`}>
  <div class="bar"></div>
  <div class="verdict-in">
    <div class="vpill">
      <svg viewBox="0 0 24 24" class="ic xs" set:html={good ? I.checkCircle : I.alert}></svg>
      {VERDICT_LABEL[data.verdict]}
    </div>
    <h1 class="vh1">{data.verdictHeadline}</h1>
    <p class="vsum">{data.summary}</p>
    <div class="vmeta">
      <span class="vchip"><svg viewBox="0 0 24 24" class="ic sm orange" set:html={I.calendar}></svg> Last verified: <strong>{verifiedDate}</strong></span>
      <a class="ext" href={safeUrl(data.officialSource.url)} target="_blank" rel="noopener noreferrer nofollow">Official source: {data.officialSource.label} <svg viewBox="0 0 24 24" class="ic xs" set:html={I.externalLink}></svg></a>
      {status !== 'verified' && <span class="vchip warn">Awaiting human review</span>}
    </div>
  </div>
</section>

<div class="layout">
  <div class="col-main">
    <!-- Visa types -->
    <section class="card">
      <div class="card-head">
        <span class="card-ic"><svg viewBox="0 0 24 24" class="ic" set:html={I.fileText}></svg></span>
        <div><h2>Visa types &amp; details</h2><p class="sub">Choose a visa category to see its details — all options for {from.name} → {to.name}.</p></div>
      </div>
      <div class="card-body">
        <div class="vselect-wrap">
          <select id="visa-select" class="vselect" aria-label="Select visa type">
            {data.visaOptions.map((o, i) => <option value={i}>{o.type}</option>)}
          </select>
          <svg viewBox="0 0 24 24" class="ic vchev" set:html={I.chevron}></svg>
        </div>
        <div id="visa-panels">
          {data.visaOptions.map((o, i) => (
            <div class="vpanel" data-i={i} hidden={i !== 0}>
              <div class="vpanel-type"><span class="dot"></span>{o.type}</div>
              <div class="vfields">
                {o.validity && <div class="field"><div class="flabel">Validity</div><div class="fval">{o.validity}</div></div>}
                {o.maxStay && <div class="field"><div class="flabel">Max stay</div><div class="fval">{o.maxStay}</div></div>}
                {o.entries && <div class="field"><div class="flabel">Entries</div><div class="fval">{o.entries}</div></div>}
                {data.processingTime && <div class="field"><div class="flabel">Processing time</div><div class="fval">{data.processingTime}</div></div>}
              </div>
              {o.eligibility && <div class="bestfor"><div class="flabel">Best for</div><p>{o.eligibility}</p></div>}
              <div class="feerow">
                <span class="muted">Government fee: fees vary by visa type and nationality and change often.</span>
                <a class="ext" href={safeUrl(data.officialSource.url)} target="_blank" rel="noopener noreferrer nofollow">Check the official fee portal <svg viewBox="0 0 24 24" class="ic xs" set:html={I.externalLink}></svg></a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Documents checklist -->
    <section class="card" id="iov-docs">
      <div class="card-head">
        <span class="card-ic"><svg viewBox="0 0 24 24" class="ic" set:html={I.fileCheck}></svg></span>
        <div><h2>Documents checklist</h2><p class="sub" id="doc-sub">Tick items as you collect them — 0 of {data.documents.length} ready.</p></div>
      </div>
      <div class="card-body">
        <div class="progress"><div class="progress-fill" id="doc-fill" style="width:0%"></div></div>
        <ul class="docs">
          {data.documents.map((d) => (
            <li>
              <label class="doc">
                <input type="checkbox" class="doc-check" />
                <span class="doc-text"><span class="doc-name">{d.label}</span>{d.note && <span class="doc-desc">{d.note}</span>}</span>
              </label>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- How to apply -->
    <section class="card">
      <div class="card-head">
        <span class="card-ic"><svg viewBox="0 0 24 24" class="ic" set:html={I.mapPin}></svg></span>
        <div><h2>How &amp; where to apply</h2><p class="sub">Follow these steps in order.</p></div>
      </div>
      <div class="card-body">
        <ol class="steps">
          {data.applySteps.map((s: any, i: number) => (
            <li class="step">
              <div class="step-n">{i + 1}</div>
              <div class="step-body">
                <div class="step-title">{s.title ?? s.text}</div>
                {s.desc && <p class="step-desc">{s.desc}</p>}
                {s.link && <a class="ext" href={safeUrl(s.link.url)} target="_blank" rel="noopener noreferrer nofollow">{s.link.label} <svg viewBox="0 0 24 24" class="ic xs" set:html={I.externalLink}></svg></a>}
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- Trip essentials -->
    <section class="card">
      <div class="card-head">
        <span class="card-ic"><svg viewBox="0 0 24 24" class="ic" set:html={I.sparkles}></svg></span>
        <div><h2>Trip essentials</h2><p class="sub">Hand-picked tools for your {to.name} trip.</p></div>
      </div>
      <div class="card-body">
        <div class="ess-grid">
          {ESSENTIALS.map((e) => (
            <div class="ess">
              <div class="ess-t"><svg viewBox="0 0 24 24" class="ic sm orange" set:html={I[e.icon]}></svg> {e.title}</div>
              <p class="ess-d">{e.desc}</p>
              <div class="ess-cta"><a href="#">{e.cta} <svg viewBox="0 0 24 24" class="ic xs" set:html={I.arrowRight}></svg></a><span class="soon">Soon</span></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Things to know -->
    <section class="card">
      <div class="card-head">
        <span class="card-ic"><svg viewBox="0 0 24 24" class="ic" set:html={I.bookOpen}></svg></span>
        <div><h2>Things to know &amp; places to visit</h2><p class="sub">Practical tips and top destinations.</p></div>
      </div>
      <div class="card-body">
        <ul class="tips">
          {data.tips.map((t) => (
            <li><svg viewBox="0 0 24 24" class="ic sm orange" set:html={I.info}></svg><span>{t}</span></li>
          ))}
        </ul>
        <div class="know-grid">
          {data.bestTimeToVisit && (
            <div class="know-best"><div class="flabel orange-l">Best time to visit</div><p>{data.bestTimeToVisit}</p></div>
          )}
          {data.topPlaces?.length && (
            <div class="know-places"><div class="flabel">Top places</div><ul>{data.topPlaces.map((p) => <li>📍 <strong>{p}</strong></li>)}</ul></div>
          )}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="card">
      <div class="card-head">
        <span class="card-ic"><svg viewBox="0 0 24 24" class="ic" set:html={I.info}></svg></span>
        <div><h2>Frequently asked questions</h2></div>
      </div>
      <div class="card-body">
        <ul class="faqs">
          {data.faq.map((f, i) => (
            <li class={`faq-item${i === 0 ? ' open' : ''}`}>
              <button type="button" class="faq-q"><span>{f.q}</span><svg viewBox="0 0 24 24" class="ic chev" set:html={I.chevron}></svg></button>
              <div class="faq-a"><div class="faq-a-in"><p>{f.a}</p></div></div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <div class="disc">
      <svg viewBox="0 0 24 24" class="ic sm orange" set:html={I.alert}></svg>
      <p>This page is AI-assisted and last verified on <strong>{verifiedDate}</strong>. Visa rules change — always confirm on the <a class="ext" href={safeUrl(data.officialSource.url)} target="_blank" rel="noopener noreferrer nofollow">official source <svg viewBox="0 0 24 24" class="ic xs" set:html={I.externalLink}></svg></a> before you travel.</p>
    </div>
  </div>

  <!-- Sidebar -->
  <aside class="col-side">
    <div class="side-card">
      <div class="flabel">At a glance</div>
      <dl class="glance">
        <div><dt>Verdict</dt><dd class="orange">{VERDICT_LABEL[data.verdict]}</dd></div>
        {opt?.maxStay && <div><dt>Max stay</dt><dd>{opt.maxStay}</dd></div>}
        {data.processingTime && <div><dt>Processing</dt><dd>{data.processingTime}</dd></div>}
        {opt?.entries && <div class="last"><dt>Entries</dt><dd>{opt.entries}</dd></div>}
      </dl>
    </div>

    <div class="side-card">
      <div class="side-head"><svg viewBox="0 0 24 24" class="ic sm orange" set:html={I.shield}></svg><div class="flabel">Official sources</div></div>
      <ul class="src">
        {data.sources.map((s) => (
          <li><a class="ext" href={safeUrl(s.url)} target="_blank" rel="noopener noreferrer nofollow">{s.label} <svg viewBox="0 0 24 24" class="ic xs" set:html={I.externalLink}></svg></a></li>
        ))}
      </ul>
    </div>

    <div class="ad-slot"><div class="flabel">Advertisement</div><p class="muted">Ad slot reserved</p></div>
  </aside>
</div>

<style>
  .crumbs { display: flex; align-items: center; gap: .5rem; font-size: .875rem; color: var(--muted-foreground); margin-bottom: 1.5rem; flex-wrap: wrap; }
  .crumbs a { color: inherit; } .crumbs a:hover { color: var(--primary); }
  .crumbs .here { color: var(--navy); font-weight: 600; }

  .ic { width: 1.25rem; height: 1.25rem; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; flex: none; }
  .ic.sm { width: 1rem; height: 1rem; } .ic.xs { width: .85rem; height: .85rem; }
  .orange { color: var(--primary); }
  .muted { color: var(--muted-foreground); }
  .flabel { font-size: .625rem; text-transform: uppercase; letter-spacing: .12em; color: var(--muted-foreground); font-weight: 700; }
  .flabel.orange-l { color: var(--primary); }

  .ext { display: inline-flex; align-items: center; gap: .25rem; color: var(--primary); font-weight: 600; text-decoration: underline; text-decoration-color: color-mix(in oklab, var(--primary) 40%, transparent); text-underline-offset: 4px; text-decoration-thickness: 2px; }
  .ext:hover { text-decoration-color: var(--primary); }

  /* Verdict */
  .verdict { position: relative; overflow: hidden; border-radius: 1.5rem; background: var(--background); border: 1px solid var(--border); box-shadow: var(--shadow-soft); }
  .verdict .bar { position: absolute; left: 0; top: 0; bottom: 0; width: 6px; background: var(--primary); }
  .verdict.good .bar { background: var(--success); }
  .verdict-in { padding: 1.5rem; }
  @media (min-width: 640px) { .verdict-in { padding: 2.5rem; } }
  .vpill { display: inline-flex; align-items: center; gap: .5rem; border-radius: 999px; background: color-mix(in oklab, var(--primary) 10%, transparent); color: var(--primary); padding: .375rem .75rem; font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; }
  .verdict.good .vpill { background: color-mix(in oklab, var(--success) 12%, transparent); color: var(--success); }
  .vh1 { margin-top: 1.25rem; font-family: var(--font-display); font-weight: 800; color: var(--navy); line-height: 1.15; text-wrap: balance; font-size: clamp(1.75rem, 4vw, 3rem); }
  .vsum { margin-top: 1.25rem; color: color-mix(in oklab, var(--navy) 75%, transparent); font-size: 1.0625rem; line-height: 1.6; max-width: 48rem; }
  .vmeta { margin-top: 1.75rem; display: flex; flex-wrap: wrap; align-items: center; gap: .75rem; }
  .vchip { display: inline-flex; align-items: center; gap: .5rem; border-radius: 999px; background: var(--cream); border: 1px solid var(--border); padding: .5rem 1rem; font-size: .875rem; color: color-mix(in oklab, var(--navy) 80%, transparent); }
  .vchip strong { color: var(--navy); }
  .vchip.warn { background: color-mix(in oklab, var(--primary) 8%, transparent); color: var(--primary); border-color: color-mix(in oklab, var(--primary) 30%, transparent); font-weight: 700; }

  /* Layout */
  .layout { margin-top: 2.5rem; display: grid; grid-template-columns: 1fr 320px; gap: 2rem; align-items: start; }
  @media (max-width: 1024px) { .layout { grid-template-columns: 1fr; } }
  .col-main { display: flex; flex-direction: column; gap: 2.5rem; min-width: 0; }
  .col-side { display: flex; flex-direction: column; gap: 1.5rem; position: sticky; top: 7rem; }
  @media (max-width: 1024px) { .col-side { position: static; } }

  /* Card */
  .card { border-radius: 1.5rem; background: var(--background); border: 1px solid var(--border); box-shadow: var(--shadow-soft); padding: 1.5rem; }
  @media (min-width: 640px) { .card { padding: 2rem; } }
  .card-head { display: flex; align-items: flex-start; gap: 1rem; }
  .card-ic { width: 2.75rem; height: 2.75rem; border-radius: .75rem; background: color-mix(in oklab, var(--primary) 10%, transparent); color: var(--primary); display: grid; place-items: center; flex: none; }
  .card-head h2 { font-family: var(--font-display); font-weight: 700; color: var(--navy); font-size: clamp(1.25rem, 2.5vw, 1.5rem); }
  .card-head .sub { margin-top: .375rem; font-size: .875rem; color: var(--muted-foreground); }
  .card-body { margin-top: 1.5rem; }

  /* Visa dropdown */
  .vselect-wrap { position: relative; }
  .vselect { width: 100%; appearance: none; -webkit-appearance: none; border: 2px solid var(--primary); background: color-mix(in oklab, var(--primary) 5%, transparent); border-radius: .75rem; padding: 1rem 3rem 1rem 1.25rem; font-family: var(--font-display); font-weight: 700; color: var(--navy); font-size: 1rem; cursor: pointer; }
  .vselect:focus { outline: none; box-shadow: 0 0 0 3px color-mix(in oklab, var(--primary) 20%, transparent); }
  .vchev { position: absolute; right: 1.25rem; top: 50%; transform: translateY(-50%); color: var(--primary); pointer-events: none; }
  .vpanel { margin-top: 1rem; border-radius: .75rem; background: var(--cream); border: 1px solid var(--border); padding: 1.5rem; }
  .vpanel[hidden] { display: none; }
  .vpanel-type { display: inline-flex; align-items: center; gap: .5rem; font-size: .875rem; font-weight: 700; color: var(--primary); }
  .vpanel-type .dot { width: .5rem; height: .5rem; border-radius: 999px; background: var(--primary); }
  .vfields { margin-top: 1.25rem; display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  @media (max-width: 540px) { .vfields { grid-template-columns: 1fr; } }
  .fval { margin-top: .25rem; color: var(--navy); font-weight: 600; line-height: 1.4; }
  .bestfor { margin-top: 1.25rem; } .bestfor p { margin-top: .25rem; color: color-mix(in oklab, var(--navy) 85%, transparent); }
  .feerow { margin-top: 1.25rem; padding-top: 1rem; border-top: 1px solid var(--border); display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: .75rem; font-size: .875rem; }

  /* Documents */
  .progress { height: .5rem; width: 100%; border-radius: 999px; background: var(--cream); overflow: hidden; margin-bottom: 1.25rem; }
  .progress-fill { height: 100%; background: var(--primary); transition: width .3s; }
  .docs { list-style: none; }
  .docs li { border-top: 1px solid var(--border); }
  .docs li:first-child { border-top: none; }
  .doc { display: flex; gap: 1rem; padding: 1rem 0; cursor: pointer; }
  .doc input { margin-top: .15rem; width: 1.25rem; height: 1.25rem; accent-color: var(--primary); cursor: pointer; flex: none; }
  .doc-name { display: block; font-family: var(--font-display); font-weight: 700; color: var(--navy); }
  .doc.checked .doc-name { text-decoration: line-through; opacity: .5; }
  .doc-desc { display: block; margin-top: .25rem; font-size: .875rem; color: color-mix(in oklab, var(--navy) 70%, transparent); line-height: 1.5; }

  /* Steps */
  .steps { list-style: none; display: flex; flex-direction: column; gap: 1.25rem; }
  .step { display: flex; gap: 1rem; }
  .step-n { width: 2.25rem; height: 2.25rem; border-radius: 999px; background: var(--primary); color: var(--primary-foreground); display: grid; place-items: center; font-family: var(--font-display); font-weight: 700; flex: none; }
  .step-title { font-family: var(--font-display); font-weight: 700; color: var(--navy); font-size: 1.125rem; }
  .step-desc { margin-top: .25rem; color: color-mix(in oklab, var(--navy) 75%, transparent); line-height: 1.6; }
  .step-body .ext { margin-top: .5rem; }

  /* Essentials */
  .ess-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 540px) { .ess-grid { grid-template-columns: 1fr; } }
  .ess { border-radius: 1rem; background: var(--cream); border: 1px solid var(--border); padding: 1.25rem; transition: border-color .2s, box-shadow .2s; }
  .ess:hover { border-color: color-mix(in oklab, var(--primary) 40%, transparent); box-shadow: 0 4px 10px rgba(0,0,0,.05); }
  .ess-t { display: flex; align-items: center; gap: .5rem; font-family: var(--font-display); font-weight: 700; color: var(--navy); }
  .ess-d { margin-top: .5rem; font-size: .875rem; color: color-mix(in oklab, var(--navy) 70%, transparent); }
  .ess-cta { margin-top: .75rem; display: flex; align-items: center; gap: .5rem; }
  .ess-cta a { display: inline-flex; align-items: center; gap: .25rem; font-size: .875rem; font-weight: 600; color: var(--primary); text-decoration: underline; text-decoration-color: color-mix(in oklab, var(--primary) 40%, transparent); text-underline-offset: 4px; }
