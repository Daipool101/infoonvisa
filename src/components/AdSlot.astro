---
import { getEnv } from '../lib/supabase';

interface Props {
  slot?: string;
  format?: string;
  label?: string;
  minHeight?: number;
}

const { slot = '', format = 'auto', label = 'Advertisement', minHeight = 250 } = Astro.props;
const client = getEnv().PUBLIC_ADSENSE_CLIENT;
---

<div class="adwrap" style={`min-height:${minHeight}px`}>
  <span class="adlabel">{label}</span>
  {client && slot ? (
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={client}
      data-ad-slot={slot}
      data-ad-format={format}
      data-full-width-responsive="true"></ins>
    <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  ) : (
    <div class="placeholder">Ad slot reserved</div>
  )}
</div>

<style>
  .adwrap {
    background: #fff;
    border: 1px dashed var(--brand-soft);
    border-radius: 14px;
    padding: 14px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 6px;
    justify-content: center;
  }
  .adlabel {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .placeholder { color: var(--muted); font-size: 13px; }
</style>
