---
import Base from '../layouts/Base.astro';
import BrandNav from '../components/BrandNav.astro';
import BrandFooter from '../components/BrandFooter.astro';
import '../styles/brand.css';

const I: Record<string, string> = {
  mail: '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  edit: '<path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/>',
  handshake: '<path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/><path d="m21 3 1 11h-2"/><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/><path d="M3 4h8"/>',
  arrowRight: '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>',
  phone: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>',
  pin: '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>',
  linkedin: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>',
  instagram: '<rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>',
};
const EMAIL = 'contact@infoonvisa.com';
const PHONE_DISPLAY = '+91 93247 62926';
const PHONE_TEL = '+919324762926';
const LOCATION = 'Mumbai, Maharashtra, India';
const LINKEDIN = 'https://www.linkedin.com/company/infoonvisa1/';
const INSTAGRAM = 'https://www.instagram.com/infoonvisa';
const REASONS = [
  { icon: 'edit', title: 'Report a correction', desc: 'Spotted a visa rule that looks out of date or wrong? Tell us the route and the official source — we take accuracy seriously and fix fast.' },
  { icon: 'handshake', title: 'Partnerships', desc: 'Insurance, eSIM, booking or eVisa partners: reach out if you serve travellers well. We only link partners we’d use ourselves.' },
  { icon: 'mail', title: 'General questions', desc: 'Feedback, press, or anything else about how InfoOnVisa works. We read every message.' },
];
---

<Base
  title="Contact InfoOnVisa — corrections, partnerships & feedback"
  description="Get in touch with the InfoOnVisa team. Report a visa-information correction, ask about partnerships, or send general feedback."
  hideChrome={true}
>
  <div class="brand">
    <BrandNav active="contact" />

    <section class="chero">
      <div class="glow" aria-hidden="true"></div>
      <div class="container chero-in reveal">
        <span class="kicker">Contact us</span>
        <h1 class="chero-h1">We’d love to <span class="ul">hear from you</span>.</h1>
        <p class="chero-sub">
          Questions, corrections, or partnership ideas — send us a note and we’ll get back to you,
          usually within 1–2 business days.
        </p>
        <a href={`mailto:${EMAIL}`} class="cbtn">
          <svg viewBox="0 0 24 24" class="ic sm" set:html={I.mail}></svg>
          {EMAIL}
        </a>

        <div class="cdetails">
          <a href={`mailto:${EMAIL}`} class="cdet">
            <span class="cdet-ic"><svg viewBox="0 0 24 24" class="ic sm" set:html={I.mail}></svg></span>
            <span><span class="cdet-l">Email</span>{EMAIL}</span>
          </a>
          <a href={`tel:${PHONE_TEL}`} class="cdet">
            <span class="cdet-ic"><svg viewBox="0 0 24 24" class="ic sm" set:html={I.phone}></svg></span>
            <span><span class="cdet-l">Phone</span>{PHONE_DISPLAY}</span>
          </a>
          <div class="cdet">
            <span class="cdet-ic"><svg viewBox="0 0 24 24" class="ic sm" set:html={I.pin}></svg></span>
            <span><span class="cdet-l">Location</span>{LOCATION}</span>
          </div>
          <a href={LINKEDIN} target="_blank" rel="noopener" class="cdet">
            <span class="cdet-ic"><svg viewBox="0 0 24 24" class="ic sm" set:html={I.linkedin}></svg></span>
            <span><span class="cdet-l">LinkedIn</span>@infoonvisa1</span>
          </a>
          <a href={INSTAGRAM} target="_blank" rel="noopener" class="cdet">
            <span class="cdet-ic"><svg viewBox="0 0 24 24" class="ic sm" set:html={I.instagram}></svg></span>
            <span><span class="cdet-l">Instagram</span>@infoonvisa</span>
          </a>
        </div>
      </div>
    </section>

    <section class="container csec">
      <div class="reveal csec-head">
        <span class="kicker">What can we help with?</span>
        <h2 class="ch2">Reach out about…</h2>
      </div>
      <div class="cgrid">
        {REASONS.map((r) => (
          <div class="ccard reveal">
            <span class="cic"><svg viewBox="0 0 24 24" class="ic" set:html={I[r.icon]}></svg></span>
            <h3>{r.title}</h3>
            <p>{r.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="container cband reveal">
      <div class="cband-in">
        <div>
          <h2 class="ch2">A quick heads-up</h2>
          <p>
            InfoOnVisa is an <strong>information service</strong> — we don’t process visa applications,
            take payments for visas, or represent any government. For applications, always use the official
            portal linked on each route page. We can’t check your personal eligibility or application status.
          </p>
        </div>
        <a href="/" class="cbtn ghost">Search a route <svg viewBox="0 0 24 24" class="ic sm" set:html={I.arrowRight}></svg></a>
      </div>
    </section>

    <BrandFooter />
  </div>
</Base>

<style>
  .chero { position: relative; overflow: hidden; padding: 4.5rem 0 2.5rem; }
  .glow { position: absolute; top: -30%; left: 50%; transform: translateX(-50%); width: 40rem; height: 30rem; background: radial-gradient(closest-side, color-mix(in oklab, var(--primary) 22%, transparent), transparent); filter: blur(20px); z-index: 0; }
  .chero-in { position: relative; z-index: 1; text-align: center; max-width: 44rem; }
  .chero-h1 { font-family: var(--font-display); font-weight: 800; font-size: clamp(2rem, 5vw, 3.25rem); line-height: 1.05; color: var(--navy); margin: .5rem 0 1rem; }
  .ul { position: relative; white-space: nowrap; }
  .ul::after { content: ''; position: absolute; left: 0; right: 0; bottom: .08em; height: .32em; background: color-mix(in oklab, var(--primary) 35%, transparent); border-radius: 1em; z-index: -1; }
  .chero-sub { color: color-mix(in oklab, var(--navy) 72%, transparent); font-size: 1.05rem; line-height: 1.65; max-width: 34rem; margin: 0 auto 1.75rem; }
  .cbtn { display: inline-flex; align-items: center; gap: .55rem; background: var(--primary); color: #fff; font-weight: 700; padding: .85rem 1.5rem; border-radius: 999px; box-shadow: var(--shadow); transition: transform .15s, box-shadow .15s; }
  .cbtn:hover { transform: translateY(-2px); box-shadow: 0 12px 28px color-mix(in oklab, var(--primary) 30%, transparent); }
  .cbtn.ghost { background: #fff; color: var(--navy); border: 1px solid var(--border); box-shadow: none; }
  .cbtn.ghost:hover { border-color: var(--primary); color: var(--primary); }
  .cnote { margin-top: 1rem; font-size: .875rem; color: color-mix(in oklab, var(--navy) 60%, transparent); }

  .cdetails { margin-top: 2rem; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .75rem; max-width: 34rem; margin-inline: auto; text-align: left; }
  @media (max-width: 560px) { .cdetails { grid-template-columns: 1fr; } }
  .cdet { display: flex; align-items: center; gap: .75rem; background: #fff; border: 1px solid var(--border); border-radius: .9rem; padding: .8rem 1rem; box-shadow: var(--shadow-sm); color: var(--navy); font-weight: 600; font-size: .925rem; transition: border-color .15s, transform .15s; }
  a.cdet:hover { border-color: var(--primary); transform: translateY(-2px); }
  .cdet-ic { display: inline-grid; place-items: center; width: 2.1rem; height: 2.1rem; border-radius: .6rem; background: color-mix(in oklab, var(--primary) 12%, #fff); color: var(--primary); flex-shrink: 0; }
  .cdet-l { display: block; font-size: .72rem; font-weight: 700; letter-spacing: .03em; text-transform: uppercase; color: color-mix(in oklab, var(--navy) 55%, transparent); }

  .csec { padding: 2.5rem 1.5rem 1rem; }
  .csec-head { text-align: center; margin-bottom: 2rem; }
  .ch2 { font-family: var(--font-display); font-weight: 800; font-size: clamp(1.5rem, 3vw, 2rem); color: var(--navy); }
  .cgrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  @media (max-width: 820px) { .cgrid { grid-template-columns: 1fr; } }
  .ccard { background: #fff; border: 1px solid var(--border); border-radius: 1.1rem; padding: 1.5rem; box-shadow: var(--shadow-sm); }
  .cic { display: inline-grid; place-items: center; width: 2.75rem; height: 2.75rem; border-radius: .8rem; background: color-mix(in oklab, var(--primary) 12%, #fff); color: var(--primary); margin-bottom: .9rem; }
  .ccard h3 { font-family: var(--font-display); font-weight: 700; color: var(--navy); margin-bottom: .4rem; font-size: 1.05rem; }
  .ccard p { color: color-mix(in oklab, var(--navy) 70%, transparent); line-height: 1.6; font-size: .925rem; }

  .cband { padding: 2rem 1.5rem 3rem; }
  .cband-in { background: color-mix(in oklab, var(--navy) 5%, #fff); border: 1px solid var(--border); border-radius: 1.25rem; padding: 2rem; display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; }
  .cband-in p { color: color-mix(in oklab, var(--navy) 72%, transparent); line-height: 1.65; margin-top: .5rem; max-width: 46rem; }
  @media (max-width: 720px) { .cband-in { flex-direction: column; align-items: flex-start; } }

  .ic { width: 1.4rem; height: 1.4rem; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .ic.sm { width: 1.05rem; height: 1.05rem; }
  .kicker { display: inline-block; font-size: .8rem; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; color: var(--primary); }
</style>
