---
import Base from '../layouts/Base.astro';
import SearchBar from '../components/SearchBar.astro';

Astro.response.status = 404;
---

<Base title="Route not found — InfoOnVisa" noindex={true}>
  <div class="wrap notfound">
    <span class="big">✈️</span>
    <h1>We couldn’t find that route</h1>
    <p class="muted">The page may have moved, or that country pair isn’t supported yet. Try searching below.</p>
    <SearchBar />
    <a href="/" class="back">← Back to home</a>
  </div>
</Base>

<style>
  .notfound { max-width: 620px; padding: 60px 20px; text-align: center; }
  .big { font-size: 48px; }
  .notfound h1 { font-size: 28px; margin: 16px 0 8px; }
  .notfound :global(.searchbar) { margin-top: 24px; text-align: left; }
  .back { display: inline-block; margin-top: 18px; }
</style>
