</style>

<script>
  // Reveal-on-scroll
  const io = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }),
    { rootMargin: '-60px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

  // Hero parallax on the floating images
  const floats = Array.from(document.querySelectorAll<HTMLElement>('.float'));
  let ticking = false;
  function parallax() {
    const sy = window.scrollY;
    floats.forEach((f) => {
      const speed = Number(f.dataset.speed || 0);
      f.style.transform = `translateY(${-(sy / 800) * speed}px)`;
    });
    ticking = false;
  }
  window.addEventListener('scroll', () => { if (!ticking) { requestAnimationFrame(parallax); ticking = true; } }, { passive: true });

  // FAQ accordion
  document.querySelectorAll('.faq-q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const wasOpen = item?.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach((i) => i.classList.remove('open'));
      if (!wasOpen) item?.classList.add('open');
    });
  });

  // Search: reflect ISO code + navigate to the corridor
  const form = document.getElementById('iov-search') as HTMLFormElement | null;
  if (form) {
    const fromSel = form.querySelector('select[name="from"]') as HTMLSelectElement;
    const toSel = form.querySelector('select[name="to"]') as HTMLSelectElement;
    const codes = form.querySelectorAll<HTMLElement>('[data-code]');
    const sync = () => {
      codes[0].textContent = fromSel.selectedOptions[0].dataset.iso || '';
      codes[1].textContent = toSel.selectedOptions[0].dataset.iso || '';
    };
    fromSel.addEventListener('change', sync);
    toSel.addEventListener('change', sync);
    sync();
    form.querySelector('.swap')?.addEventListener('click', () => {
      const t = fromSel.value; fromSel.value = toSel.value; toSel.value = t; sync();
    });
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (fromSel.value === toSel.value) { toSel.focus(); return; }
      window.location.href = `/${fromSel.value}-to-${toSel.value}`;
    });
  }
</script>
