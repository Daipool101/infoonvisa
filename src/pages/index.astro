---
import Base from '../layouts/Base.astro';
import { COUNTRIES } from '../lib/countries';

const options = [...COUNTRIES].sort((a, b) => a.name.localeCompare(b.name));

// Popular routes → real corridor slugs.
const ROUTES = [
  { slug: 'india-to-united-arab-emirates', img: '/images/uae.jpg', from: 'IN', to: 'AE', name: 'India to United Arab Emirates', tag: 'Visa on arrival' },
  { slug: 'india-to-thailand', img: '/images/thailand.jpg', from: 'IN', to: 'TH', name: 'India to Thailand', tag: 'eVisa available' },
  { slug: 'india-to-singapore', img: '/images/singapore.jpg', from: 'IN', to: 'SG', name: 'India to Singapore', tag: 'eVisa required' },
  { slug: 'india-to-japan', img: '/images/japan.jpg', from: 'IN', to: 'JP', name: 'India to Japan', tag: 'eVisa required' },
  { slug: 'india-to-united-kingdom', img: '/images/uk.jpg', from: 'IN', to: 'GB', name: 'India to United Kingdom', tag: 'Standard visitor' },
  { slug: 'india-to-united-states', img: '/images/usa.jpg', from: 'IN', to: 'US', name: 'India to United States', tag: 'B1/B2 visa' },
  { slug: 'india-to-france', img: '/images/france.jpg', from: 'IN', to: 'FR', name: 'India to France', tag: 'Schengen visa' },
  { slug: 'india-to-australia', img: '/images/australia.jpg', from: 'IN', to: 'AU', name: 'India to Australia', tag: 'eVisitor / ETA' },
];

const MARQUEE = ['🇮🇳 India', '🇯🇵 Japan', '🇦🇪 UAE', '🇹🇭 Thailand', '🇸🇬 Singapore', '🇬🇧 UK', '🇺🇸 USA', '🇫🇷 France', '🇦🇺 Australia', '🇨🇦 Canada', '🇩🇪 Germany', '🇮🇹 Italy'];

const STEPS = [
  { n: 1, icon: 'search', title: 'Search a route', desc: 'Choose your passport country and destination.' },
  { n: 2, icon: 'shield', title: 'We verify & assemble', desc: 'We pull from official sources and structure it into one page.' },
  { n: 3, icon: 'fileCheck', title: 'Plan with confidence', desc: 'Documents, steps, links and tips — dated and sourced.' },
];

const FEATURES = [
  { icon: 'globe', title: '190+ countries', desc: 'From major hubs to hidden gems — every route, mapped.' },
  { icon: 'shield', title: 'Official sources only', desc: 'Every page links to embassy and government pages.' },
  { icon: 'clock', title: 'Always fresh', desc: 'A clear "last verified" date so you know it\'s current.' },
  { icon: 'mapPin', title: 'Land-ready tips', desc: 'What to do at immigration, SIM, currency, transport.' },
];

const TESTIMONIALS = [
  { name: 'Aarav S.', route: 'IN → JP', quote: 'Saved me hours of digging through embassy PDFs. The doc checklist alone was worth it.' },
  { name: 'Meera P.', route: 'IN → AE', quote: 'I booked my flight with confidence. Knowing the visa-on-arrival rules upfront was a relief.' },
  { name: 'Karan T.', route: 'IN → GB', quote: 'Clean, sourced, and actually current. No ads, no signup. Bookmarked.' },
];

const FAQS = [
  { q: 'Is the information official?', a: 'Every page links to the relevant embassy, consulate, or government source. We assemble — you can always verify at the source.' },
  { q: 'Do you process visas for me?', a: "No. We're an information service. We point you to official sources and trusted partners so you can apply confidently." },
  { q: 'How often is content updated?', a: "Every page shows a 'last verified' date. Major changes are reflected within days of publication." },
  { q: 'Do I need to sign up?', a: 'Nope. Search any route and read the full guide — no account, no paywall, no popups.' },
];

// Inline lucide icon path data (24x24, stroke).
const I: Record<string, string> = {
  plane: '<path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/>',
  arrowRight: '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>',
  swap: '<path d="M8 3 4 7l4 4"/><path d="M4 7h16"/><path d="m16 21 4-4-4-4"/><path d="M20 17H4"/>',
  search: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>',
  shield: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>',
  fileCheck: '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m9 15 2 2 4-4"/>',
  globe: '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>',
  clock: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  sparkles: '<path d="M9.94 14.06A2 2 0 0 0 8.5 12.6l-5.1-1.3a.5.5 0 0 1 0-.96l5.1-1.32A2 2 0 0 0 9.94 7.5l1.32-5.1a.5.5 0 0 1 .96 0l1.3 5.1a2 2 0 0 0 1.44 1.44l5.1 1.3a.5.5 0 0 1 0 .98l-5.1 1.3a2 2 0 0 0-1.44 1.44l-1.3 5.1a.5.5 0 0 1-.96 0z"/>',
  mapPin: '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>',
  chevron: '<path d="m6 9 6 6 6-6"/>',
};
const star = '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'InfoOnVisa',
  url: 'https://infoonvisa.com',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://infoonvisa.com/{search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<Base
  title="InfoOnVisa — Know exactly what visa you need, for any country"
  description="From → To, sorted in seconds. Verified visa requirements, documents, how to apply, and what to do when you land."
  jsonLd={jsonLd}
  hideChrome={true}
>
  <div class="home">
    <!-- NAV -->
    <header class="nav">
      <div class="container nav-inner">
        <a href="#home" class="logo">
          <span class="logo-badge"><svg viewBox="0 0 24 24" class="ic" set:html={I.plane}></svg></span>
          <span class="logo-text"><span class="navy">infoon</span> <span class="orange">visa</span></span>
        </a>
        <nav class="nav-links">
          <a href="#home">Home</a>
          <a href="#routes">Countries</a>
          <a href="#how">How it works</a>
          <a href="/blog">Blog</a>
        </nav>
        <a href="#search" class="btn-pill">Start <svg viewBox="0 0 24 24" class="ic sm" set:html={I.arrowRight}></svg></a>
      </div>
    </header>

    <!-- HERO -->
    <section id="home" class="hero">
      <div class="float jp" data-speed="80"><span class="tilt r6"><img src="/images/japan.jpg" alt="" aria-hidden="true" /></span></div>
      <div class="float th" data-speed="140"><span class="tilt rn3"><img src="/images/thailand.jpg" alt="" aria-hidden="true" /></span></div>
      <div class="float fr" data-speed="50"><span class="tilt rn6"><img src="/images/france.jpg" alt="" aria-hidden="true" /></span></div>

      <div class="glow glow-a" aria-hidden="true"></div>
      <div class="glow glow-b" aria-hidden="true"></div>

      <div class="hero-inner">
        <div class="anim" style="animation-delay:0s">
          <span class="badge"><svg viewBox="0 0 24 24" class="ic xs" set:html={I.sparkles}></svg> From → To, sorted in seconds</span>
        </div>
        <h1 class="anim hero-h1" style="animation-delay:.08s">
          Know exactly what visa <span class="ul">you need</span> — for any country, anywhere.
        </h1>
        <p class="anim hero-sub" style="animation-delay:.16s">
          Pick where you're from and where you're going. Get one clean, verified page: requirements, documents, how to apply, and what to do when you land.
        </p>

        <div class="anim" style="animation-delay:.24s" id="search">
          <form class="searchbar" id="iov-search" role="search" aria-label="Find visa requirements">
            <label class="picker">
              <span class="picker-label">From</span>
              <span class="picker-val">
                <span class="code" data-code>IN</span>
                <select name="from" aria-label="From country">
                  {options.map((c) => <option value={c.slug} data-iso={c.iso} selected={c.slug === 'india'}>{c.name}</option>)}
                </select>
              </span>
            </label>
            <button type="button" class="swap" id="iov-swap" aria-label="Swap countries"><svg viewBox="0 0 24 24" class="ic sm" set:html={I.swap}></svg></button>
            <label class="picker">
              <span class="picker-label">To</span>
              <span class="picker-val">
                <span class="code" data-code>JP</span>
                <select name="to" aria-label="To country">
                  {options.map((c) => <option value={c.slug} data-iso={c.iso} selected={c.slug === 'japan'}>{c.name}</option>)}
                </select>
              </span>
            </label>
            <button type="submit" class="search-btn"><svg viewBox="0 0 24 24" class="ic sm" set:html={I.search}></svg> Search</button>
          </form>
        </div>

        <div class="anim trust" style="animation-delay:.32s">
          <span><svg viewBox="0 0 24 24" class="ic sm" set:html={I.shield}></svg> Official sources linked</span>
          <span><svg viewBox="0 0 24 24" class="ic sm" set:html={I.fileCheck}></svg> "Last verified" date on every page</span>
          <span><svg viewBox="0 0 24 24" class="ic sm star" set:html={star}></svg> No signup</span>
        </div>

        <a href="#routes" class="anim scroll-cue" style="animation-delay:.4s">
          Explore popular routes
          <svg viewBox="0 0 24 24" class="ic sm bounce" set:html={I.chevron}></svg>
        </a>
      </div>
    </section>

    <!-- MARQUEE -->
    <div class="marquee">
      <div class="marquee-track">
        {[...MARQUEE, ...MARQUEE].map((c) => <span class="marquee-item">{c} <span class="dot">•</span></span>)}
      </div>
    </div>

    <!-- ROUTES -->
    <section id="routes" class="routes">
      <div class="container">
        <div class="reveal section-head">
          <div>
            <div class="kicker">Popular routes</div>
            <h2 class="h2">Where Indian travellers are headed</h2>
          </div>
          <a href="#" class="link-orange">View all 190+ countries →</a>
        </div>
        <div class="routes-grid">
          {ROUTES.map((r, i) => (
            <a href={`/${r.slug}`} class="reveal rcard" style={`transition-delay:${(i % 4) * 80}ms`}>
              <div class="rcard-media">
                <img src={r.img} alt={r.name} loading="lazy" width="800" height="640" />
                <div class="rcard-shade"></div>
                <div class="rcard-tag"><span>{r.from}</span><svg viewBox="0 0 24 24" class="ic xs" set:html={I.arrowRight}></svg><span>{r.to}</span></div>
                <div class="rcard-cap">
                  <div class="rcard-status">{r.tag}</div>
                  <div class="rcard-name">{r.name}</div>
                </div>
              </div>
              <div class="rcard-foot">
                <span>View guide</span>
                <svg viewBox="0 0 24 24" class="ic sm arrow" set:html={I.arrowRight}></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section id="how" class="how">
      <div class="container">
        <h2 class="reveal h2 how-title">How it works</h2>
        <div class="how-grid">
          {STEPS.map((s, i) => (
            <div class="reveal step" style={`transition-delay:${i * 80}ms`}>
              <div class="step-n">{s.n}</div>
              <svg viewBox="0 0 24 24" class="ic step-ic" set:html={I[s.icon]}></svg>
              <h3 class="step-title">{s.title}</h3>
              <p class="step-desc">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- WHY US -->
    <section class="why">
      <div class="container why-grid">
        <div class="reveal">
          <div class="kicker">Why infoonvisa</div>
          <h2 class="h2">One page. Everything you actually need.</h2>
          <p class="why-lead">No noise, no signup, no upsell. Just the verified visa info for your exact route — laid out the way travellers actually read it.</p>
          <div class="why-features">
            {FEATURES.map((f, i) => (
              <div class="reveal feature" style={`transition-delay:${i * 80}ms`}>
                <svg viewBox="0 0 24 24" class="ic feature-ic" set:html={I[f.icon]}></svg>
                <div class="feature-title">{f.title}</div>
                <div class="feature-desc">{f.desc}</div>
              </div>
            ))}
          </div>
        </div>
        <div class="reveal why-media">
          <div class="why-imgs">
            <img src="/images/japan.jpg" alt="Japan" loading="lazy" class="down" />
            <img src="/images/singapore.jpg" alt="Singapore" loading="lazy" />
            <img src="/images/uae.jpg" alt="UAE" loading="lazy" />
            <img src="/images/australia.jpg" alt="Australia" loading="lazy" class="down" />
          </div>
          <div class="verified-chip">
            <span class="verified-ic"><svg viewBox="0 0 24 24" class="ic sm" set:html={I.shield}></svg></span>
            <div>
              <div class="verified-t">Last verified</div>
              <div class="verified-d">June 24, 2026</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="tms">
      <div class="container">
        <div class="reveal tms-head">
          <div class="kicker">Loved by travellers</div>
          <h2 class="h2">Trusted before every trip</h2>
        </div>
        <div class="tms-grid">
          {TESTIMONIALS.map((t, i) => (
            <figure class="reveal tcard" style={`transition-delay:${i * 80}ms`}>
              <div class="stars">
                {Array.from({ length: 5 }).map(() => <svg viewBox="0 0 24 24" class="ic sm star" set:html={star}></svg>)}
              </div>
              <blockquote>"{t.quote}"</blockquote>
              <figcaption>
                <span class="tname">{t.name}</span>
                <span class="troute">{t.route}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="faq">
      <div class="container narrow">
        <div class="reveal faq-head">
          <div class="kicker">FAQ</div>
          <h2 class="h2">Quick answers</h2>
        </div>
        <div class="faq-list">
          {FAQS.map((f, i) => (
            <div class={`faq-item${i === 0 ? ' open' : ''}`}>
              <button type="button" class="faq-q">
                <span>{f.q}</span>
                <svg viewBox="0 0 24 24" class="ic chev" set:html={I.chevron}></svg>
              </button>
              <div class="faq-body"><div class="faq-body-inner"><p>{f.a}</p></div></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-sec">
      <div class="container cta-wrap">
        <div class="reveal cta">
          <div class="glow cta-glow-a" aria-hidden="true"></div>
          <div class="glow cta-glow-b" aria-hidden="true"></div>
          <div class="cta-inner">
            <h2 class="cta-title">Your next trip is one search away.</h2>
            <p class="cta-sub">Find your visa requirements in seconds — no signup, no spam, just the answer.</p>
            <a href="#search" class="cta-btn">Search a route <svg viewBox="0 0 24 24" class="ic sm" set:html={I.arrowRight}></svg></a>
          </div>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="foot">
      <div class="container foot-grid">
        <div>
          <div class="foot-logo"><svg viewBox="0 0 24 24" class="ic sm orange-ic" set:html={I.plane}></svg> infoonvisa</div>
          <p class="foot-desc">We don't process visas. We point you to official sources and trusted partners, with a clear "last verified" date on every page.</p>
        </div>
        <div>
          <div class="foot-h">Explore</div>
          <ul><li><a href="#search">Search a route</a></li><li><a href="#routes">Popular countries</a></li><li><a href="#how">How it works</a></li><li><a href="#faq">FAQ</a></li></ul>
        </div>
        <div>
          <div class="foot-h">Legal</div>
          <ul><li><a href="/terms">Terms</a></li><li><a href="/privacy">Privacy</a></li><li><a href="/about">About</a></li><li><a href="/blog">Blog</a></li></ul>
        </div>
      </div>
      <div class="foot-base">© 2026 InfoOnVisa · Information is AI-assisted and for guidance only — always confirm on official government sources.</div>
    </footer>
  </div>
</Base>

<style>
  .home {
    --radius: 1rem;
    --background: oklch(1 0 0);
    --foreground: oklch(0.22 0.06 280);
    --navy: oklch(0.27 0.07 280);
    --cream: oklch(0.97 0.04 90);
    --card: oklch(1 0 0);
    --primary: oklch(0.68 0.19 40);
    --primary-foreground: oklch(0.99 0 0);
    --secondary: oklch(0.97 0.04 90);
    --muted-foreground: oklch(0.5 0.04 280);
    --border: oklch(0.92 0.02 80);
    --success: oklch(0.55 0.13 145);
    --amber: 253, 230, 138;
    --shadow-soft: 0 10px 40px -10px color-mix(in oklab, var(--navy) 18%, transparent);
    --shadow-glow: 0 20px 60px -15px color-mix(in oklab, var(--primary) 45%, transparent);
    --font-display: 'Plus Jakarta Sans', system-ui, sans-serif;
    --font-body: 'Inter', system-ui, sans-serif;
    background: var(--background);
    color: var(--foreground);
    font-family: var(--font-body);
    overflow-x: hidden;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }
  .home :global(a) { text-decoration: none; }
  .container { max-width: 80rem; margin: 0 auto; padding: 0 1.5rem; }
  .container.narrow { max-width: 48rem; }
  .ic { width: 1.25rem; height: 1.25rem; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; flex: none; }
  .ic.sm { width: 1rem; height: 1rem; }
  .ic.xs { width: .85rem; height: .85rem; }
  .ic.star { fill: currentColor; stroke: none; }
  .h2 { font-family: var(--font-display); font-weight: 800; letter-spacing: -0.02em; color: var(--navy); font-size: clamp(2rem, 4vw, 3rem); line-height: 1.1; }
  .kicker { font-size: .75rem; text-transform: uppercase; letter-spacing: .12em; color: var(--primary); font-weight: 700; }
  .navy { color: var(--navy); } .orange { color: var(--primary); }

  /* NAV */
  .nav { position: sticky; top: 0; z-index: 40; backdrop-filter: blur(12px); background: color-mix(in oklab, var(--background) 80%, transparent); border-bottom: 1px solid color-mix(in oklab, var(--border) 60%, transparent); }
  .nav-inner { height: 4rem; display: flex; align-items: center; justify-content: space-between; }
  .logo { display: flex; align-items: center; gap: .625rem; }
  .logo-badge { display: grid; place-items: center; width: 2.25rem; height: 2.25rem; border-radius: .75rem; background: var(--navy); color: #fff; transition: transform .2s; }
  .logo-badge .ic { transform: rotate(-45deg); width: 1rem; height: 1rem; }
  .logo:hover .logo-badge { transform: rotate(-6deg); }
  .logo-text { font-family: var(--font-display); font-weight: 800; font-size: 1.125rem; letter-spacing: -0.02em; }
  .nav-links { display: flex; align-items: center; gap: 2.25rem; font-size: .875rem; font-weight: 500; }
  .nav-links a { color: color-mix(in oklab, var(--navy) 80%, transparent); transition: color .2s; }
  .nav-links a:hover { color: var(--primary); }
  .btn-pill { display: inline-flex; align-items: center; gap: .375rem; border-radius: 999px; background: var(--primary); color: var(--primary-foreground); font-size: .875rem; font-weight: 600; padding: .5rem 1rem; box-shadow: var(--shadow-glow); transition: transform .2s; }
  .btn-pill:hover { transform: translateY(-1px); }
  @media (max-width: 860px) { .nav-links { display: none; } }

  /* HERO */
  .hero { position: relative; padding: 5rem 0 7rem; overflow: hidden; }
  .hero-inner { position: relative; max-width: 56rem; margin: 0 auto; padding: 0 1.5rem; text-align: center; }
  .glow { position: absolute; border-radius: 999px; pointer-events: none; }
  .glow-a { top: -8rem; left: 33%; width: 500px; height: 500px; background: color-mix(in oklab, var(--primary) 15%, transparent); filter: blur(120px); }
  .glow-b { top: 10rem; right: -8rem; width: 400px; height: 400px; background: rgba(var(--amber), .4); filter: blur(100px); }
  .float { position: absolute; will-change: transform; z-index: 1; }
  .float .tilt { display: block; }
  .float img { display: block; object-fit: cover; border-radius: 1.5rem; box-shadow: var(--shadow-soft); }
  .float.jp { top: -2rem; right: 1.5rem; } .float.jp img { width: 14rem; height: 18rem; }
  .float.th { top: 10rem; right: 18rem; } .float.th img { width: 11rem; height: 11rem; }
  .float.fr { top: 18rem; left: 1.5rem; } .float.fr img { width: 10rem; height: 13rem; }
  .tilt.r6 { transform: rotate(6deg); } .tilt.rn3 { transform: rotate(-3deg); } .tilt.rn6 { transform: rotate(-6deg); }
  .float img { animation: floatUp 6s ease-in-out infinite; }
  @media (max-width: 1100px) { .float.th { display: none; } }
  @media (max-width: 1280px) { .float.fr { display: none; } }
  @media (max-width: 1023px) { .float { display: none; } }

  .badge { display: inline-flex; align-items: center; gap: .5rem; border-radius: 999px; border: 1px solid color-mix(in oklab, var(--primary) 30%, transparent); background: color-mix(in oklab, var(--primary) 5%, transparent); padding: .375rem 1rem; font-size: .75rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--primary); }
  .hero-h1 { margin-top: 1.5rem; font-family: var(--font-display); font-weight: 800; letter-spacing: -0.02em; color: var(--navy); text-wrap: balance; font-size: clamp(2.5rem, 7vw, 4.5rem); line-height: 1.05; }
  .ul { position: relative; display: inline-block; }
